{
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Link",
                    "value": "<https://mishallow.vercel.app/.well-known/api-catalog>; rel=\"api-catalog\"; type=\"application/json\""
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/((?!.*\\.).*)",
            "destination": "/index.html"
        }
    ]
}